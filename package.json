{
  "name": "neurowave",
  "version": "0.1.0",
  "private": true,
  "description": "NeuroWave Windows desktop app prototype.",
  "author": "NeuroWave",
  "main": "desktop/main.js",
  "scripts": {
    "desktop": "electron .",
    "desktop:debug": "set NEUROWAVE_ELECTRON_DEVTOOLS=1&& electron .",
    "desktop:smoke": "set NEUROWAVE_ELECTRON_SMOKE=1&& electron .",
    "package:smoke": "python scripts/smoke_desktop_package.py",
    "package:smoke:predict": "python scripts/smoke_desktop_package.py --audio playground/testpluck.wav",
    "package:win": "electron-builder --win nsis --x64",
    "package:win:dir": "electron-builder --win dir --x64",
    "runtime:prepare": "python scripts/prepare_windows_runtime.py",
    "runtime:check": "python scripts/validate_windows_runtime.py",
    "runtime:check:dev": "python scripts/validate_windows_runtime.py --runtime-dir .venv"
  },
  "build": {
    "appId": "com.neurowave.app",
    "productName": "NeuroWave",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "neurowave-python/scripts"
      },
      {
        "from": "minisynth",
        "to": "neurowave-python/minisynth"
      },
      {
        "from": "requirements.txt",
        "to": "neurowave-python/requirements.txt"
      },
      {
        "from": "requirements-cuda.txt",
        "to": "neurowave-python/requirements-cuda.txt"
      },
      {
        "from": "runtime/python",
        "to": "python-runtime",
        "filter": [
          "**/*",
          "!pyvenv.cfg",
          "!.gitignore",
          "!.gitkeep"
        ]
      },
      {
        "from": "models/v3.5_noise_detune_loss.pt",
        "to": "models/v3.5_noise_detune_loss.pt"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  }
}
